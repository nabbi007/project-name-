# Server
PORT=5000
NODE_ENV=development

# Database (cloud PostgreSQL - Neon / Supabase / Railway)
# Pooled connection used by the running app:
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"
# Direct (non-pooled) connection used by Prisma migrations.
# On Neon this is the same host without the "-pooler" suffix.
DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"

# Auth
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN=1d

# Frontend
CLIENT_URL=http://localhost:5173

# Snwolley AI — STT / TTS / Vision (hackathon key) + Agents API (platform key)
SNWOLLEY_BASE_URL=https://v1.snwolley.ai
SNWOLLEY_HACKATHON_API_KEY=your-team-hackathon-key
SNWOLLEY_AGENT_API_KEY=
SNWOLLEY_AGENT_ID=
SNWOLLEY_TIMEOUT=60000

# Cloudinary media storage (optional - falls back to local disk if unset)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=agrovoice
