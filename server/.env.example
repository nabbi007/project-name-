# Server
PORT=5000
NODE_ENV=development

# Database (cloud PostgreSQL - Neon / Supabase / Railway)
# Pooled connection used by the running app:
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"
# Direct (non-pooled) connection used by Prisma migrations.
# On Neon this is the same host without the "-pooler" suffix.
DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"

# Auth
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN=1d

# Frontend
CLIENT_URL=http://localhost:5173

# Snwolley AI APIs (keep secret, never expose to React)
# Sent as the X-API-Key header on every request.
SNWOLLEY_BASE_URL=https://v1.snwolley.ai
# Per-team hackathon key for STT / TTS / Vision (/api/v1/hackathon/*)
SNWOLLEY_HACKATHON_API_KEY=
# Snwolley platform key for the Agents API (/v1/chat/completions)
SNWOLLEY_AGENT_API_KEY=
# Agent identifier for the Agents API, e.g. "107"
SNWOLLEY_AGENT_ID=
SNWOLLEY_TIMEOUT=60000
